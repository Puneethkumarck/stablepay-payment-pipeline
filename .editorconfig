root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.java]
indent_style = space
indent_size = 4

[*.{kt,kts}]
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,json,css,scss}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.toml]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.{avsc,avro}]
indent_style = space
indent_size = 2
