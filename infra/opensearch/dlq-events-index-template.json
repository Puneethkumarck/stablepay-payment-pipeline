{
  "index_patterns": ["dlq-events*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.mapping.total_fields.limit": 20,
      "plugins.index_state_management.rollover_alias": "dlq-events-write"
    },
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "event_id": { "type": "keyword" },
        "source_topic": { "type": "keyword" },
        "source_partition": { "type": "integer" },
        "source_offset": { "type": "long" },
        "error_class": { "type": "keyword" },
        "error_message": { "type": "text" },
        "failed_at": { "type": "date", "format": "epoch_millis" },
        "retry_count": { "type": "integer" },
        "original_payload_json": { "type": "text", "index": false }
      }
    }
  }
}
